# === REQUIRED ===

# Google Gemini API Key - Get from https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# App URL - Your deployed app URL (use http://localhost:3000 for local dev)
APP_URL="http://localhost:3000"

# Port for the server (Render/Railway inject this automatically)
# PORT=3000

# === STRIPE (Required for payments) ===

# Stripe Secret Key - Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."

# Stripe Publishable Key - Get from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Webhook Secret - Get from Stripe CLI or Dashboard webhook endpoint
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Credit Pack Price ID (the one-time payment product)
# Create in Stripe Dashboard > Products > Add Product ($3 one-time)
STRIPE_CREDIT_PRICE_ID="price_xxx..."

# === FIREBASE ADMIN (Optional - for server-side user management) ===

# Path to Firebase service account JSON file
# Download from Firebase Console > Project Settings > Service Accounts
# FIREBASE_SERVICE_ACCOUNT_PATH="./service-account.json"

# === ANALYTICS (Optional) ===

# Google Analytics 4 Measurement ID
# Get from GA4 > Admin > Data Streams > your stream > Measurement ID
# VITE_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
