{
  "name": "precision-match",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "cross-env NODE_ENV=development concurrently -k \"vite --base=./\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "cross-env VITE_API_URL=https://precision-match.onrender.com vite build --base=./ && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@sentry/node": "^10.66.0",
    "@sentry/profiling-node": "^10.66.0",
    "@sentry/react": "^10.66.0",
    "@stripe/stripe-js": "^9.8.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "driver.js": "^1.8.0",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "html2canvas": "^1.4.1",
    "html2canvas-pro": "^2.0.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "stripe": "^22.2.1",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.singularityinsight.precisionmatch",
    "productName": "Precision Match",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    }
  }
}
