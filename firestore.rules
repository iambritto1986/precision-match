rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() {
      return isSignedIn() && (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || ('email' in request.auth.token && request.auth.token.email == 'iambrittothomas@gmail.com'));
    }

    function isValidUserConfig(data) {
       return data.keys().hasAll(['email', 'createdAt']) && 
              data.email is string && data.email.size() <= 256 &&
              data.createdAt is string &&
              (!data.keys().hasAny(['isPro']) || data.isPro is bool) &&
              (!data.keys().hasAny(['credits']) || data.credits is number) &&
              (!data.keys().hasAny(['stripeCustomerId']) || data.stripeCustomerId is string);
    }
    
    function isValidUserConfigUpdate(data) {
       return data.email is string && data.email.size() <= 256 &&
              (!data.keys().hasAny(['createdAt']) || data.createdAt is string) &&
              (!data.keys().hasAny(['isPro']) || data.isPro is bool) &&
              (!data.keys().hasAny(['credits']) || data.credits is number) &&
              (!data.keys().hasAny(['stripeCustomerId']) || data.stripeCustomerId is string);
    }

    match /admins/{userId} {
      allow read, list: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, list: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUserConfig(incoming());
      allow update: if (isSignedIn() && ((request.auth.uid == userId) || isAdmin()));
      
      match /resumes/{resumeId} {
        function isValidResume(data) {
          return data.keys().hasAll(['title', 'contentData', 'createdAt', 'updatedAt']) &&
                 data.keys().size() == 4 &&
                 data.title is string && data.title.size() <= 200 &&
                 data.contentData is string && data.contentData.size() <= 1048576 &&
                 data.createdAt == request.time &&
                 data.updatedAt == request.time;
        }
        function isValidResumeUpdate(data) {
           return data.title is string && data.title.size() <= 200 &&
                 data.contentData is string && data.contentData.size() <= 1048576 &&
                 data.createdAt == existing().createdAt &&
                 data.updatedAt == request.time;
        }

        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(resumeId) && isValidResume(incoming());
        allow update: if isSignedIn() && request.auth.uid == userId && isValidResumeUpdate(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'contentData', 'updatedAt']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /chats/{chatId} {
         function isValidChat(data) {
          return data.keys().hasAll(['title', 'createdAt', 'updatedAt']) &&
                 data.keys().size() == 3 &&
                 data.title is string && data.title.size() <= 200 &&
                 data.createdAt == request.time &&
                 data.updatedAt == request.time;
        }
        function isValidChatUpdate(data) {
           return data.title is string && data.title.size() <= 200 &&
                  data.createdAt == existing().createdAt &&
                  data.updatedAt == request.time;
        }
        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(chatId) && isValidChat(incoming());
        allow update: if isSignedIn() && request.auth.uid == userId && isValidChatUpdate(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);
        allow delete: if isSignedIn() && request.auth.uid == userId;

        match /messages/{messageId} {
           function isValidMessage(data) {
             return data.keys().hasAll(['role', 'text', 'createdAt']) &&
                    data.keys().size() == 3 &&
                    data.role is string && data.role.size() <= 20 &&
                    data.text is string && data.text.size() <= 1048576 &&
                    data.createdAt == request.time;
           }
           allow read, list: if isSignedIn() && request.auth.uid == userId;
           allow create: if isSignedIn() && request.auth.uid == userId && isValidId(messageId) && isValidMessage(incoming());
           // Immutable after creation
           allow delete: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }
  }
}
